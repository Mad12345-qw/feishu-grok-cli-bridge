PORT=3000
SERVICE_NAME=feishu-gpt55-research-bridge

FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=replace_me
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

GPT55_BASE_URL=http://64.81.116.93:8317
GPT55_API_KEY=
GPT55_MODEL=gpt-5.5
GPT55_WEB_SEARCH_ENABLED=true
FEISHU_CARD_HEADER_TEMPLATE=default
FEISHU_CARD_BANNER_IMAGE_KEY=

# Legacy Grok CLI settings are kept for the original bridge code paths, but normal chat uses GPT55 Responses.
GROK_DEPLOYMENT_KEY=
GROK_AUTH_JSON_B64=
GROK_CLI_ENABLED=false
GROK_CLI_TIMEOUT_MS=540000
GROK_CLI_COMMAND=grok
GROK_CLI_CWD=
GROK_MEDIA_MAX_TURNS=10
GROK_VIDEO_MAX_TURNS=10
GROK_VIDEO_MODEL=grok-build
GROK_MEMORY_ENABLED=true
GROK_STATE_SYNC_ENABLED=true
GROK_STATE_REDIS_KEY=feishu-grok-bridge:grok-state
GROK_REMOTE_STATE_SSH_HOST=
GROK_REMOTE_STATE_SSH_PORT=22
GROK_REMOTE_STATE_SSH_USER=root
GROK_REMOTE_STATE_SSH_PASSWORD=
GROK_REMOTE_STATE_DIR=/opt/grok-state-backups/feishu-grok-bridge
GROK_CLI_ARGS_JSON=["--no-auto-update","--always-approve","--permission-mode","bypassPermissions","--max-turns","10","--cwd","{{cwd}}","--output-format","streaming-json","-p","{{prompt}}"]

MAX_CARD_CONTENT_CHARS=90000
MAX_REPLY_CHARS=3500
MAX_IMAGE_BYTES=10485760
MAX_VIDEO_BYTES=31457280
DEBUG_TOKEN=
